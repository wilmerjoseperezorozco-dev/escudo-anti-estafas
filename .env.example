# ─────────────────────────────────────────────
# WPM Digital Infrastructure — Environment
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Odysseus AI Workspace
ODYSSEUS_ADMIN_USER=admin
ODYSSEUS_ADMIN_PASSWORD=change_me_strong_password

# Ollama (local LLM host)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# SearXNG
SEARXNG_SECRET=change_me_random_secret_48_chars

# Timezone
TZ=America/Bogota

# n8n
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_strong_password
WEBHOOK_URL=http://localhost:5678/
